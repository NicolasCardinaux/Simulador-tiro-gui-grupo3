{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "shot_result.schema.json",
  "title": "ShotResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "type",
    "shot_id",
    "timestamp",
    "source",
    "result",
    "feedback"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0"
    },
    "type": {
      "type": "string",
      "const": "shot_result"
    },
    "shot_id": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "module"
      ],
      "properties": {
        "module": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "result": {
      "type": "string",
      "enum": [
        "hit",
        "miss"
      ]
    },
    "feedback": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "led",
        "duration_ms"
      ],
      "properties": {
        "led": {
          "type": "string",
          "enum": [
            "green",
            "red"
          ]
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 1,
          "maximum": 60000
        }
      }
    },
    "coordinates": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "x",
        "y"
      ],
      "properties": {
        "x": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4095
        },
        "y": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4095
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
